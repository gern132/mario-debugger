{
  "name": "rn-quality-checker",
  "version": "1.0.0",
  "description": "React Native Quality Checker for macOS",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "build": {
    "appId": "com.tripledot.rn-quality-checker",
    "productName": "Mario",
    "publish": null,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg"]
    },
    "directories": {
      "buildResources": "build",
      "output": "dist"
    }
  }
}
